# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
backend/venv/
backend/.venv/
venv/
.venv/
env/
ENV/
*.egg-info/
dist/
build/

# external data repos (Perseus Digital Library)
backend/data/perseus/canonical-greekLit/
backend/data/perseus/canonical-latinLit/
.aider*

# supabase
supabase/.temp/
.env*.local
backend/.next/
.claude/worktrees/
.worktrees/

# Firecrawl scrape artifacts
.firecrawl/

# data backups (reversible DB snapshots, not code)
backend/backups/

# stray hashed uv lock files (real lock is backend/uv.lock)
/uv-*.lock

# tiktoken tokenizer cache (created at runtime, not code)
data-gym-cache/

# Local marketing drafts / trackers (not part of the app)
*.xlsx
.~lock.*#
/*_Draft.md
