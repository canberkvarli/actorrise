{
  "expo": {
    "name": "ActorRise",
    "slug": "actorrise",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "actorrise",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.actorrise.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "ActorRise records your voice so ScenePartner can rehearse scenes with you.",
        "UIBackgroundModes": ["audio"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.actorrise.app",
      "adaptiveIcon": {
        "backgroundColor": "#CB4B00",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow ActorRise to access the microphone for ScenePartner rehearsals."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#CB4B00",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1cbd4e95-8c78-4ae3-a0a9-45844bfdb43a"
      }
    }
  }
}
